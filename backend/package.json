{
  "name": "tzeva-adom-backend",
  "version": "1.0.0",
  "description": "Backend for Israeli Alert Dashboard",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:backfill": "tsx src/backfill.ts",
    "db:backfill-csv": "tsx src/backfill-csv.ts"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^1.0.0-rc.3",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^1.0.0-rc.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
